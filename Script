-- ==========================================
-- 2. LÓGICA DE INYECCIÓN DE INVENTARIO
-- ==========================================

local player = game:GetService("Players").LocalPlayer
local isOn = false

-- Función dedicada a clonar el ítem directo al inventario del cliente
local function executeInventoryDupe()
	local character = player.Character
	if not character then return end

	-- 1. Escanear lo que el jugador tiene sostenido físicamente en la mano
	for _, child in pairs(character:GetChildren()) do
		if child:IsA("Tool") then
			-- Duplicación en el Inventario Clásico de Roblox (Backpack)
			local toolClone = child:Clone()
			toolClone.Parent = player:FindFirstChild("Backpack")
			print("Item clonado en Backpack clásica: " .. toolClone.Name)
		end
	end

	-- 2. Adaptabilidad para sistemas de inventario personalizado (GUI / Carpetas de datos)
	-- Busca carpetas comunes de datos que los desarrolladores usan para guardar inventarios locales
	local localDataFolders = {
		player:FindFirstChild("Data"),
		player:FindFirstChild("Inventory"),
		player:FindFirstChild("leaderstats")
	}

	for _, folder in pairs(localDataFolders) do
		if folder then
			-- Buscar si hay valores correspondientes al ítem de la mano para inflar su número
			for _, itemValue in pairs(folder:GetChildren()) do
				if itemValue:IsA("IntValue") or itemValue:IsA("NumberValue") then
					-- Duplica visualmente el contador (ej: cambia un contador de semillas de 1 a 99)
					itemValue.Value = itemValue.Value * 2 
					print("Multiplicador aplicado a variable local: " .. itemValue.Name)
				end
			end
		end
	end

	-- 3. Soporte para Slots visuales de Inventarios Customizados
	local playerGui = player:FindFirstChild("PlayerGui")
	if playerGui then
		-- Escanea interfaces comunes que simulan inventarios (como marcos con grillas de ítems)
		for _, gui in pairs(playerGui:GetDescendants()) do
			if gui:IsA("Frame") and (string.find(string.lower(gui.Name), "inv") or string.find(string.lower(gui.Name), "slot")) then
				-- Si encuentra un recuadro o botón de ítem, simula la creación visual de un nuevo casillero
				for _, slot in pairs(gui:GetChildren()) do
					if slot:IsA("ImageLabel") or slot:IsA("TextButton") then
						local visualSlotClone = slot:Clone()
						visualSlotClone.Parent = gui -- Duplica la celda del objeto en tu pantalla
						print("Celda de interfaz duplicada en la grilla visual")
						break
					end
				end
			end
		end
	end
end

toggleButton.MouseButton1Click:Connect(function()
	isOn = not isOn
	if isOn then
		toggleButton.Text = "ON"
		toggleButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
		print("Grow a Garden 2 - DUPE INVENTARIO: ON")
		
		executeInventoryDupe() -- Ejecuta la inyección directo al almacén
	else
		toggleButton.Text = "OFF"
		toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
		print("Grow a Garden 2 - DUPE INVENTARIO: OFF")
		
		-- Nota: Al ser cliente, volver a apagar o reiniciar limpia los efectos locales no guardados
	end
end)

-- ==========================================
-- 3. SCRIPT PARA ARRASTRAR LA VENTANA (DRAG)
-- ==========================================

local UserInputService = game:GetService("UserInputService")
local dragging, dragInput, dragStart, startPos

local function update(input)
	local delta = input.Position - dragStart
	mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

mainFrame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end
end)

mainFrame.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInput and dragging then update(input) end
end)

